# Gmail credentials for contact form
# 1. Enable 2-Step Verification on your Gmail account
# 2. Go to Google Account → Security → App Passwords
# 3. Generate a new App Password (select "Mail" + "Other")
# 4. Paste the 16-character password below (no spaces)

GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# The email address that receives all contact form submissions
CONTACT_EMAIL=help.goqatar@gmail.com
